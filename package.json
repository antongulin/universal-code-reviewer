{
  "name": "universal-code-reviewer",
  "version": "0.1.0",
  "description": "AI-powered code reviews using any OpenAI-compatible LLM. No vendor lock-in, no usage quotas.",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antongulin/universal-code-reviewer.git"
  },
  "bugs": {
    "url": "https://github.com/antongulin/universal-code-reviewer/issues"
  },
  "homepage": "https://github.com/antongulin/universal-code-reviewer#readme",
  "scripts": {
    "build": "tsc && ncc build dist/index.js -o dist",
    "dev": "ts-node src/main.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "package": "ncc build dist/index.js -o dist --license licenses.txt"
  },
  "keywords": [
    "github-action",
    "code-review",
    "llm",
    "ai",
    "openai",
    "ollama",
    "self-hosted"
  ],
  "author": "antongulin",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^20.0.2",
    "openai": "^4.28.4"
  },
  "overrides": {
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
